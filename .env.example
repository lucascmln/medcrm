# ─── Banco de dados ───────────────────────────────────────────────────────────
# Produção: PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/medcrm?sslmode=require"

# Desenvolvimento local com SQLite (remova em produção):
# DATABASE_URL="file:./dev.db"

# ─── NextAuth / Auth.js ───────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="sua-chave-secreta-aqui-minimo-32-chars"

# URL pública da aplicação (sem barra final)
NEXTAUTH_URL="https://seudominio.com.br"
APP_BASE_URL="https://seudominio.com.br"

# ─── Webhooks Meta / WhatsApp ─────────────────────────────────────────────────
# Tokens de verificação — defina valores aleatórios e configure no painel Meta
META_VERIFY_TOKEN="token-aleatorio-meta"
WHATSAPP_VERIFY_TOKEN="token-aleatorio-whatsapp"

# ─── Opcional: Upload de imagens ─────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""
